{
  "manifest_version": 3,
  "name": "卡淘猎手",
  "version": "1.0.0",
  "description": "提供卡淘页面关键词过滤、高亮与快速关注功能，提升浏览效率。",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "*://*.cardhobby.com.cn/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "打开控制台",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.cardhobby.com.cn/*"
      ],
      "css": [
        "assets/base.css",
        "modules/RadarSlot/radar.css",
        "modules/BatchBidSlot/batch.css",
        "modules/SniperSlot/sniper.css"
      ],
      "js": [
        "core/config.js",
        "core/Utils.content.js",
        "core/ContentEngine.js",
        "modules/RadarSlot/radar.content.js",
        "modules/BatchBidSlot/batch.content.js",
        "modules/SniperSlot/sniper.content.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}